# Tradenerves Backend Environment Variables
# Copy this file to .env and fill in your actual API keys

# Polygon.io API Key (required for fetching stock data)
POLYGON_API_KEY=your_polygon_api_key_here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Database Path (optional - defaults to db/stocks.db)
DATABASE_PATH=db/stocks.db
